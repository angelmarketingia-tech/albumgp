# --- Database (Postgres / Neon) -------------------------------------------
# Pooled connection string (use this in the app at runtime). For 300k-user
# scale this MUST go through the Neon pooler or the app exhausts Postgres
# connections under load and requests hang. Use the `-pooler` host and add
# `?pgbouncer=true&connection_limit=1`. The app refuses to boot in production
# if this doesn't look pooled (see lib/db/client.ts → assertPooledUrlInProd).
# Example:
#   postgresql://USER:PASS@ep-xxxx-pooler.us-east-1.aws.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL=
# Direct (non-pooled) connection. Required by `prisma migrate` and other DDL.
# This is the NON `-pooler` host. Never used by the app at runtime.
DIRECT_DATABASE_URL=
# Escape hatch: set to 1 only if your managed pooler doesn't use the `-pooler`
# hostname token (the boot check then trusts you). Leave empty for Neon.
DB_POOLER_OK=

# --- Redis (Upstash) ------------------------------------------------------
# Either a single connection string...
REDIS_URL=
# ...or the Upstash REST pair (preferred on Vercel edge).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Central platform webhook --------------------------------------------
# Outbound signed webhook fired by /api/redeem (built in Phase 3).
WEBHOOK_CENTRAL_URL=
# HMAC-SHA256 shared secret. MINIMUM 32 bytes of randomness.
# Generate with: openssl rand -hex 32   (or: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))")
# NEVER commit a real value. NEVER expose to the client bundle.
WEBHOOK_CENTRAL_SECRET=

# --- Rate limiting --------------------------------------------------------
# Defaults applied by lib/security/with-rate-limit.ts when individual endpoints
# don't override. See SECURITY.md for the per-endpoint matrix.
# Requests per minute per IP across non-sensitive endpoints.
RATE_LIMIT_IP_PER_MIN=10
# Requests per minute per code-hash (anti brute-force on a single code).
RATE_LIMIT_CODE_PER_MIN=5

# --- Auth (Auth.js v5) ----------------------------------------------------
# Secret used to sign JWT session cookies. REQUIRED in production.
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# Mock credentials password for dev only. NEVER set this in production —
# the mock provider hard-fails if NODE_ENV=production.
MOCK_AUTH_PASSWORD=
# Allowed mock accounts (dev only). Defaults defined in lib/auth/auth-config.ts.
# Override comma-separated if you need a different whitelist locally.
MOCK_AUTH_ALLOWED_EMAILS=

# --- Public app metadata --------------------------------------------------
NEXT_PUBLIC_APP_NAME=GanaPlay Album
# Origen público de producción. Usado por metadataBase (OpenGraph/Twitter URLs
# absolutas) y debe coincidir con el dominio donde se sirve la app — el WebView
# de Capacitor carga la app desde acá. En dev defaultea a http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://albumgp.vercel.app
