# Plantilla de credenciales de firma para el .aab de release.
#
# 1) Generá tu keystore (una sola vez, GUARDALO seguro fuera del repo):
#      keytool -genkeypair -v -keystore ganaplay-album-release.keystore \
#        -alias ganaplay-album -keyalg RSA -keysize 2048 -validity 10000
#
# 2) Copiá este archivo a android/keystore.properties (SIN .example) y completá:
#      cp keystore.properties.example keystore.properties
#
# 3) keystore.properties está gitignoreado — NUNCA se commitea.
#
# storeFile puede ser ruta absoluta o relativa a android/.

storeFile=../ruta/segura/ganaplay-album-release.keystore
storePassword=TU_CONTRASEÑA_DEL_KEYSTORE
keyAlias=ganaplay-album
keyPassword=TU_CONTRASEÑA_DE_LA_CLAVE
